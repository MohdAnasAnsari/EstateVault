# App
MOCK_SERVICES=true
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://vault:vault@localhost:5432/vault_dev

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# File Storage (Cloudflare R2 — S3-compatible)
R2_BUCKET_NAME=vault-assets
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_PUBLIC_URL=https://your-r2-domain.com

# AI (OpenAI — only needed when MOCK_SERVICES=false)
OPENAI_API_KEY=

# Maps
MAPBOX_TOKEN=

# Auth providers (optional OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# KYC — Jumio (only when MOCK_SERVICES=false)
JUMIO_API_TOKEN=
JUMIO_API_SECRET=

# SMS — Twilio (only when MOCK_SERVICES=false)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email — Resend (only when MOCK_SERVICES=false)
RESEND_API_KEY=

# Payments — Stripe (only when MOCK_SERVICES=false)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# WebRTC TURN — Cloudflare (only when MOCK_SERVICES=false)
CLOUDFLARE_TURN_USERNAME=
CLOUDFLARE_TURN_TOKEN=

# DLD / RERA (only when MOCK_SERVICES=false)
DLD_API_KEY=

# Forex (only when MOCK_SERVICES=false)
FOREX_API_KEY=
