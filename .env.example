# App
MOCK_SERVICES=true
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_URL=http://localhost:4000/api/v1
API_PORT=4000
DISABLE_JOBS=false

# Database
DATABASE_URL=postgresql://vault:vault@localhost:5432/vault_dev

# Redis
REDIS_URL=redis://localhost:6379

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# File Storage (Cloudflare R2 - S3 compatible)
R2_BUCKET_NAME=vault-assets
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_PUBLIC_URL=https://your-r2-domain.com

# AI (only needed when MOCK_SERVICES=false)
OPENAI_API_KEY=

# Maps
MAPBOX_TOKEN=

# Auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# KYC (only when MOCK_SERVICES=false)
JUMIO_API_TOKEN=
JUMIO_API_SECRET=

# SMS (only when MOCK_SERVICES=false)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (only when MOCK_SERVICES=false)
RESEND_API_KEY=

# Payments (only when MOCK_SERVICES=false)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# WebRTC TURN (only when MOCK_SERVICES=false)
CLOUDFLARE_TURN_USERNAME=
CLOUDFLARE_TURN_TOKEN=

# DLD / RERA (only when MOCK_SERVICES=false)
DLD_API_KEY=

# Forex (only when MOCK_SERVICES=false)
FOREX_API_KEY=
