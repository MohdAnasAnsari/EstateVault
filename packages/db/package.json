{
  "name": "@vault/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema.d.ts",
      "default": "./dist/src/schema.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "drizzle-kit": "^0.30.1",
    "@types/node": "^22.10.2"
  },
  "dependencies": {
    "@vault/mocks": "workspace:*",
    "@vault/types": "workspace:*",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "dotenv": "^16.4.7"
  }
}
